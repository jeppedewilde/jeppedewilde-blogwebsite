---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Home">
  <div class="bento-grid home-grid">
    
    <div class="bento-tile col-span-2 row-span-2 intro-tile">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="content-wrapper">
        <h1>Jeppe de Wilde</h1>
        <p>Something about me?</p>
      </div>
    </div>

    <a href="/werk" class="bento-tile col-span-2 tile-link accent-bg" transition:name="bento-werk">
      <div class="tile-content">
        <h2>Mijn Werk</h2>
        <p>Bekijk de projecten van deze minor</p>
      </div>
      <span class="arrow">&rarr;</span>
    </a>

    <a href="/blog" class="bento-tile col-span-1 tile-link" transition:name="bento-blog">
      <div class="tile-content">
        <h2>Blogs</h2>
        <p>Weekly Nerds</p>
      </div>
      <span class="arrow">&rarr;</span>
    </a>

    <div class="bento-tile col-span-1 nav-tile">
      <h3>Menu</h3>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/werk">Mijn Werk</a></li>
        <li><a href="/blog">Blogs</a></li>
      </ul>
    </div>

    <a href="/leerdoelen" class="bento-tile col-span-4 tile-link" transition:name="bento-leerdoelen">
      <div class="tile-content">
        <h2>Focus voor de Meesterproef</h2>
        <p>Componenten, Toegankelijkheid & Leiderschap</p>
      </div>
      <span class="arrow">&rarr;</span>
    </a>

    <div class="bento-tile col-span-4 marquee-tile">
      <div class="marquee-content">
        <span class="ticker-text">HTML5 • CSS Grid & Subgrid • Astro • View Transitions • Accessibility (WCAG) • WebSockets • Component-Driven •</span>
        <span class="ticker-text">HTML5 • CSS Grid & Subgrid • Astro • View Transitions • Accessibility (WCAG) • WebSockets • Component-Driven •</span>
      </div>
    </div>

  </div>
</MainLayout>

<style>
  /* =========================================================================
     LOCK SCROLLING (Alleen op desktop!)
     We gebruiken :global() zodat we de tags in de MainLayout kunnen bereiken
     ========================================================================= */
  @media (min-width: 768px) {
    :global(body) {
      height: 100vh;
      overflow: hidden; /* Blokkeert het scrollen volledig */
    }
    
    :global(main) {
      height: 100vh;
      display: flex;
      align-items: center; /* Centreert het grid perfect in het midden van je scherm */
      padding: 1.5rem;
    }

    /* We dwingen de home-grid om precies 100% van de hoogte te vullen */
    .home-grid {
      height: 100%;
      max-height: 900px; /* Zorgt dat tegels niet belachelijk ver uitrekken op enorme schermen */
      /* We maken 4 rijen: 3 even grote (1fr) en de marquee mag iets smaller (80px) */
      grid-template-rows: repeat(3, 1fr) 80px; 
      grid-auto-rows: unset; /* Heft de standaard bento.css regels op */
    }
  }

/* =========================================================================
     1. INTRO TILE (Uniek voor Homepage)
     ========================================================================= */
  .intro-tile { justify-content: flex-end; }
  .intro-tile h1 { font-size: clamp(2rem, 4vw, 3.5rem); letter-spacing: -0.03em; }
  .content-wrapper p { max-width: 90%; }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    z-index: 1;
    opacity: 0.25;
    animation: zweven 12s infinite alternate ease-in-out;
  }
  .blob-1 { width: 300px; height: 300px; background-color: var(--primary-color); top: -80px; left: -80px; }
  .blob-2 { width: 200px; height: 200px; background-color: #ec4899; bottom: -50px; right: -50px; animation-delay: -5s; }
  @keyframes zweven { 100% { transform: translate(40px, 40px) scale(1.1); } }

  /* =========================================================================
     2. LINK TILES
     ========================================================================= */
  .tile-link {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-end;
    transition: all 0.3s ease;
  }

  .tile-content { display: flex; flex-direction: column; }
  
  .tile-link h2 { color: var(--text-color); margin: 0 0 0.25rem 0; font-size: 1.6rem; transition: color 0.3s ease; }
  .tile-link p { opacity: 0.7; margin: 0; font-size: 1.05rem; }

  .arrow { font-size: 1.5rem; color: var(--primary-color); transition: transform 0.3s ease; opacity: 0; transform: translateX(-10px); }

  .tile-link:hover { background-color: #233045; }
  .tile-link:hover h2 { color: var(--primary-color); }
  .tile-link:hover .arrow { opacity: 1; transform: translateX(0); }

  /* =========================================================================
     3. NAVIGATIE TILE
     ========================================================================= */
  .nav-tile { justify-content: center; background-color: transparent; }
  .nav-tile h3 { margin: 0 0 1rem 0; color: var(--primary-color); font-size: 1.2rem; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.8; }
  .nav-tile ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .nav-tile a { color: var(--text-color); text-decoration: none; opacity: 0.6; transition: opacity 0.2s, padding-left 0.2s; font-weight: 500; font-size: 1.1rem; }
  .nav-tile a:hover { opacity: 1; color: var(--primary-color); padding-left: 5px; }

/* =========================================================================
     4. MARQUEE TILE
     ========================================================================= */
  .marquee-tile { 
    display: flex; 
    align-items: center; 
    padding: 1.5rem 0; /* Padding aan de zijkant weggehaald zodat hij van rand tot rand loopt */
    background-color: var(--primary-color); 
    border: none; 
    /* justify-content: center; is hier bewust WEGGEHAALD! */
  }

  .marquee-content { 
    display: flex; 
    width: max-content; 
    animation: scroll-ticker 30s linear infinite; 
  }

  .ticker-text { 
    font-family: monospace; 
    font-weight: bold; 
    color: #0f172a; 
    padding-right: 1.5rem; 
    font-size: 1.2rem; 
    text-transform: uppercase; 
  }

  @keyframes scroll-ticker { 
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); } 
  }
</style>