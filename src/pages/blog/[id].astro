---
// src/pages/blog/[id].astro
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection, render } from 'astro:content';

// check welke pagina's gegenereerd moeten worden op basis van de MD/MDX-bestanden
// getStaticPaths is een verplichte ingebouwde functie van Astro voor dynamische routes
export async function getStaticPaths() {

    // haal alle projecten op uit de werk content collectie
  const blogs = await getCollection('blog');

    // loop (map) door de lijst met projecten
  return blogs.map(post => ({
    // bepaal URL van de pagina (/werk/naam-blog)
    params: { id: post.id },

    // stuur data van project naar de pagina
    props: { post },
  }));
}
// pak de project data
const { post } = Astro.props;

// zet inhoud .md file naar html -> render geeft component 'content' (html element <Content />)
const { Content } = await render(post);
---

<MainLayout title={post.data.title}>
  <div id="lees-balk" class="progress-bar"></div>
  <article class="blog-detail">
    <header class="blog-header">
      <a href="/blog" class="back-link">&larr; Terug naar Blogs</a>
      <span class={`type-badge ${post.data.type === 'reflectie' ? 'is-reflectie' : ''}`}>
        {post.data.type.replace('-', ' ')}
</span>
      <h1 transition:name={`blog-titel-${post.id}`}>{post.data.title}</h1>
      <time>{post.data.datum.toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
    </header>

    <section class="blog-body">
      <Content />
    </section>
  </article>
</MainLayout>

<style>
  /* MARK: detail container 
  */
  .blog-detail {
    max-width: 800px;
    margin: 2rem auto;
    background: var(--card-bg);
    border-radius: 24px;
    border: 1px solid var(--border-color);
    padding: 1rem;
  }

  /* MARK: header/nav 
  */
  .blog-header {
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 2rem;
    margin-bottom: 2rem;
  }

  .back-link { 
    display: inline-block; 
    color: var(--primary-color); 
    text-decoration: none; 
    font-weight: 600; 
    margin-bottom: 1.5rem; 
  }
  
  .back-link:hover { 
    text-decoration: underline; 
    color: var(--accent-2);
  }

  /* MARK: badge/header typografie 
  */
  .type-badge {
    display: block;
    padding: 0.2rem 0.6rem;
    background: var(--border-color);
    color: var(--accent-3);
    border-radius: 8px;
    font-size: 0.85rem;
    width: fit-content;
    margin-bottom: 1rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .type-badge.is-reflectie {
    color: var(--accent-1);
  }

  .blog-header h1 { 
    font-size: 2.5rem; 
    margin: 0 0 0.75rem 0; 
    color: var(--text-color); 
    line-height: 1.2; 
  }
  
  .blog-header time { 
    opacity: 0.6; 
    font-size: 0.95rem; 
  }

  /* MARK: markdown content 
  */
  .blog-body { 
    font-size: 1.1rem; 
    line-height: 1.8; 
    opacity: 0.95; 
  }
  
  .blog-body :global(h2) { 
    color: var(--primary-color); 
    margin-top: 2.5rem; 
    margin-bottom: 1rem; 
    font-size: 1.6rem; 
  }
  
  .blog-body :global(p) { 
    margin-bottom: 1.5rem; 
  }
  
  .blog-body :global(ul) { 
    margin-left: 1.5rem; 
    margin-bottom: 1.5rem; 
  }
  
  .blog-body :global(li) { 
    margin-bottom: 0.5rem; 
  }
</style>

<script>
  // omdat we view transitions gebruiken astro:page-load
  document.addEventListener('astro:page-load', () => {
    const progressBar = document.getElementById('lees-balk');
    
    // stop als balk niet bestaat
    if (!progressBar) return;

    // rekenlogica
    const updateProgressBar = () => {
      // hoeveel pixels vanaf bovenkant pagina
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      
      // totale scrollbare ruimte
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      
      if (height > 0) {
        // bereken percentage
        const scrolled = (winScroll / height) * 100;
        // Pas de breedte van het balkje aan
        progressBar.style.width = scrolled + "%";
      }
    };

    // luister naar scrollen gebruiker
    window.addEventListener('scroll', updateProgressBar);

    // ruim scroll listener op bij verlaten pagina
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', updateProgressBar);
    }, { once: true });
  });
</script>