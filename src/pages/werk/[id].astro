---
// src/pages/werk/[id].astro
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

// check welke pagina's gegenereerd moeten worden op basis van de MD/MDX-bestanden
// getStaticPaths is een verplichte ingebouwde functie van Astro voor dynamische routes
export async function getStaticPaths() {
  
  // haal alle projecten op uit de werk content collectie
  const projecten = await getCollection('werk');
  
  // loop (map) door de lijst met projecten
  return projecten.map(project => ({
    // bepaal URL van de pagina (/werk/naam-vak)
    params: { id: project.id },

    // stuur data van project naar de pagina
    props: { project },
  }));
}

// pak de project data
const { project } = Astro.props;

// zet inhoud .md file naar html -> render geeft component 'content' (html element <Content />)
const { Content } = await render(project);
---

<MainLayout title={project.data.title}>
  <div id="lees-balk" class="progress-bar"></div>
  <article class="project-detail">
    
    <header class="project-hero">
      {project.data.cover && (
        <Image 
          src={project.data.cover} 
          alt={project.data.alt_tekst || project.data.title} 
          class="hero-bg"
        />
      )}
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <a href="/werk" class="back-btn">&larr; Terug naar Werk</a>
        <h1 transition:name={`title-${project.id}`}>{project.data.title}</h1>
        {project.data.omschrijving && <p class="lead">{project.data.omschrijving}</p>}
      </div>
    </header>

    <section class="project-body">
      <div class="project-meta">
        {project.data.vak && (
          <div class="meta-item">
            <span class="meta-label">Vak</span>
            <span class="meta-value">{project.data.vak}</span>
          </div>
        )}
        {project.data.docent && (
          <div class="meta-item">
            <span class="meta-label">Docent</span>
            <span class="meta-value">{project.data.docent}</span>
          </div>
        )}
        {project.data.cijfer && (
          <div class="meta-item">
            <span class="meta-label">Resultaat</span>
            <span class="meta-value-badge">{project.data.cijfer}</span>
          </div>
        )}
      </div>

      {project.data.live_url && (
        <div class="live-preview-section">
          <div class="iframe-wrapper">
            <div class="browser-bar">
              <span class="dot"></span>
              <span class="dot"></span>
              <span class="dot"></span>
            </div>
            <iframe 
              src={project.data.live_url} 
              title={`Live preview van ${project.data.title}`} 
              loading="lazy"
            ></iframe>
          </div>
          
          <a href={project.data.live_url} target="_blank" rel="noopener noreferrer" class="live-btn">
            Bekijk volledige applicatie in nieuw venster &nearr;
          </a>
        </div>
      )}
      
      <Content />
    </section>

  </article>
</MainLayout>

<style>
  /* MARK: detail container 
  */
  .project-detail {
    max-width: 900px;
    margin: 0 auto;
    background: var(--card-bg);
    border-radius: 24px;
    border: 1px solid var(--border-color);
    overflow: hidden;
  }

  /* MARK: hero section 
  */
  .project-hero {
    position: relative;
    min-height: 40vh;
    display: flex;
    align-items: flex-end;
    padding: 3rem 2rem;
  }

  .hero-bg {
    position: absolute;
    top: 0; 
    left: 0; 
    width: 100%; 
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .hero-overlay {
    position: absolute; 
    top: 0; 
    left: 0; 
    width: 100%; 
    height: 100%;
    background: linear-gradient(to top, var(--card-bg) 0%, rgba(0,0,0,0.4) 100%);
    z-index: 2;
  }

  /* MARK: hero content 
  */
  .hero-content { 
    position: relative; 
    z-index: 3; 
    width: 100%; 
  }
  
  .back-btn {
    display: inline-block;
    color: #ffffff;
    text-decoration: none;
    font-weight: 600;
    margin-bottom: 1.5rem;
    background: rgba(255,255,255,0.1);
    padding: 0.5rem 1rem;
    border-radius: 50px;
    backdrop-filter: blur(5px);
    transition: background 0.2s;
  }

  .back-btn:hover { 
    background: rgba(255,255,255,0.2);
    color: var(--accent-2); 
  }

  .hero-content h1 { 
    font-size: clamp(2.5rem, 5vw, 4rem); 
    margin: 0 0 0.5rem 0; 
    color: #ffffff; 
    line-height: 1.1; 
  }

  .hero-content .lead { 
    font-size: 1.2rem; 
    color: #ffffff; 
    margin: 0; 
  }

  /* MARK: markdown content 
  */
  .project-body {
    padding: 3rem 2rem;
    color: var(--text-color);
    font-size: 1.1rem;
    line-height: 1.8;
  }
  
  .project-body :global(h2) { 
    color: var(--primary-color); 
    margin-top: 2rem; 
    margin-bottom: 1rem; 
    font-size: 1.8rem; 
  }

  .project-body :global(p) { 
    margin-bottom: 1.5rem; 
    opacity: 0.9; 
  }

  .project-body :global(ul) { 
    margin-left: 1.5rem; 
    margin-bottom: 1.5rem; 
  }

  /* MARK: live preview 
  */
  .live-preview-section {
    margin: 0 0 3rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .iframe-wrapper {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border-color);
    background: var(--bg-color);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05); 
  }

  .browser-bar {
    background: var(--intro-bg-start);
    padding: 0.75rem 1rem;
    display: flex;
    gap: 8px;
    border-bottom: 1px solid var(--border-color);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--border-color); 
    opacity: 0.7;
  }

  .browser-bar:hover .dot:nth-child(1) { 
    background: #ff5f56; 
    opacity: 1; 
  }

  .browser-bar:hover .dot:nth-child(2) { 
    background: #ffbd2e; 
    opacity: 1; 
  }

  .browser-bar:hover .dot:nth-child(3) { 
    background: #27c93f; 
    opacity: 1; 
  }

  .iframe-wrapper iframe {
    width: 100%;
    height: 600px; 
    border: none;
    display: block;
    background: #ffffff; 
  }

  .live-btn {
    display: flex;
    justify-content: center;
    align-items: center;
    width: fit-content;
    align-self: flex-start;
    padding: 0.75rem 1.5rem;
    background: var(--card-bg-2);
    color: var(--text-color);
    text-decoration: none;
    font-weight: 600;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .live-btn:hover {
    background: var(--primary-color);
    color: var(--bg-color);
    border-color: var(--primary-color);
  }

  @media (max-width: 768px) {
    .iframe-wrapper {
      display: none;
    }

    .live-btn {
      width: 100%;
      padding: 1.25rem;
      background: var(--primary-color);
      color: var(--bg-color);
      font-size: 1.1rem;
    }
  }

  /* MARK: metadata 
  */
  .project-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-color); 
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .meta-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--primary-color); 
    font-weight: 600;
  }

  .meta-value {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-color);
  }

  .meta-value-badge {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-color);
    background: var(--badge-bg); 
    padding: 2px 10px;
    border-radius: 6px;
    width: fit-content;
  }

  @media (max-width: 600px) {
    .project-meta {
      gap: 1.5rem;
    }
  }
</style>

<script>
  // omdat we view transitions gebruiken astro:page-load
  document.addEventListener('astro:page-load', () => {
    const progressBar = document.getElementById('lees-balk');
    
    // stop als balk niet bestaat
    if (!progressBar) return;

    // rekenlogica
    const updateProgressBar = () => {
      // hoeveel pixels vanaf bovenkant pagina
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      
      // totale scrollbare ruimte
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      
      if (height > 0) {
        // bereken percentage
        const scrolled = (winScroll / height) * 100;
        // Pas de breedte van het balkje aan
        progressBar.style.width = scrolled + "%";
      }
    };

    // luister naar scrollen gebruiker
    window.addEventListener('scroll', updateProgressBar);

    // ruim scroll listener op bij verlaten pagina
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', updateProgressBar);
    }, { once: true });
  });
</script>