---
// src/pages/werk/index.astro
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const alleProjecten = await getCollection("werk");

// zoek meesterproef in alle projecten
const meesterproef = alleProjecten.find(p => p.id === 'meesterproef');

// Verzamel alle andere projecten in een nieuwe lijst
const overigeProjecten = alleProjecten.filter(p => p.id !== 'meesterproef');

// zet meesterproef op 1 (zodat deze rechtsboven in het grid komt) en plak de rest erachteraan
const projecten = [meesterproef, ...overigeProjecten].filter(Boolean);

// tegels in grid laten passen
const getBentoClass = (index) => {
  if (index === 0) return "col-span-2 row-span-2";
  if (index === 1) return "col-span-2 row-span-1";
  if (index === 2) return "col-span-1 row-span-2";
  if (index === 3) return "col-span-1 row-span-1";
  if (index === 4) return "col-span-2 row-span-1";
  if (index === 5) return "col-span-1 row-span-1";
  if (index === 6) return "col-span-2 row-span-1";
  return "col-span-1 row-span-1";
};
---

<MainLayout title="Mijn Werk">
  <div class="bento-grid werk-grid">
    <div
      class="bento-tile col-span-2 row-span-1 intro-tile"
      transition:name="bento-werk"
    >
      <div class="content-wrapper">
        <a href="/" class="back-link">&larr; Terug naar Home</a>
        <h1>Mijn Werk</h1>
        <p>Een overzicht van alle projecten gebouwd tijdens deze minor.</p>
      </div>
    </div>

    {
      projecten.map((project, index) => (
        <a
          href={`/werk/${project.id}`}
          class={`bento-tile project-tile ${getBentoClass(index)}`}
        >
          {project.data.cover && (
            <Image
              src={project.data.cover}
              alt={project.data.alt_tekst || project.data.title}
              class="project-bg"
            />
          )}
          <div class="overlay" />
          <div class="content">
            <h2 transition:name={`title-${project.id}`}>
              {project.data.title}
            </h2>
            <p class="omschrijving">{project.data.omschrijving}</p>
          </div>
        </a>
      ))
    }
  </div>
</MainLayout>

<style>
  /* MARK: layout, scroll, grid 
  */
  .werk-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (min-width: 500px) {
    .werk-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    :global(body) {
      height: 100vh;
      overflow: hidden;
    }
    
    :global(main) {
      height: 100vh;
      display: flex;
      align-items: center;
      padding: 1.5rem;
    }

    .werk-grid {
      height: 100%;
      max-height: 85vh;
      grid-template-columns: repeat(4, 1fr); 
      grid-template-rows: repeat(4, 1fr); 
      grid-auto-rows: unset;
    }
  }

  /* MARK: intro tile 
  */
  .intro-tile {
    justify-content: center;
    padding: 1.5rem 2rem;
    background: var(--card-bg-2);
    transition: background 0.3s ease;
  }

  .intro-tile h1 {
    font-size: clamp(2rem, 3vw, 2.5rem);
  }

  /* MARK: project tiles 
  */
  .project-tile {
    justify-content: flex-end;
    padding: 1.5rem;
    border: none;
    background-color: var(--intro-bg-start);
    min-height: 280px; 
  }

  @media (min-width: 768px) {
    .project-tile {
      min-height: 0; 
    }
  }

  /* MARK: img 
  */
  .project-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    filter: grayscale(100%) opacity(0.4);
    transition: transform 0.5s ease, filter 0.5s ease;
    will-change: transform, filter;
    backface-visibility: hidden;
    transform: translateZ(0);
  }

  .project-tile:hover .project-bg {
    transform: scale(1.05);
    filter: grayscale(0%) opacity(1);
  }

  /* MARK: overlay gradients 
  */
  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, var(--overlay-bg) 0%, var(--overlay-bg) 40%, transparent 100%);
    z-index: 2;
    transition: background 0.3s ease;
  }

  .project-tile:hover .overlay {
    background: linear-gradient(to top, var(--overlay-bg) 0%, transparent 80%);
  }

  /* MARK: text & content 
  */
  .content {
    position: relative;
    z-index: 3;
  }
  
  .content h2 {
    margin: 0 0 0.25rem 0;
    color: var(--text-on-image);
    font-size: 1.15rem; 
    line-height: 1.3;
    transition: color 0.3s ease;
  }
  
  .project-tile:hover .content h2 {
    color: var(--text-on-image);
  }

  .content .omschrijving {
    margin: 0;
    color: var(--text-on-image);
    opacity: 0.75;
    font-size: 0.9rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>