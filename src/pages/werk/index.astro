---
// src/pages/werk/index.astro
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const projecten = await getCollection("werk");

// Slimme functie om tegels een asymmetrisch patroon te geven
const getBentoClass = (index) => {
  if (index === 0) return "col-span-2 row-span-2"; // Eerste project krijgt een extra grote tegel
  if (index === 1 || index === 2) return "col-span-1 row-span-1"; // Kleine vierkantjes
  if (index === 3) return "col-span-2 row-span-1"; // Een brede tegel
  if (index === 4 || index === 5) return "col-span-1 row-span-1"; // Kleine vierkantjes
  return "col-span-1 row-span-1"; // Fallback
};
---

<MainLayout title="Mijn Werk">
  <div class="home-wrapper">
    <div class="bento-grid werk-grid">
      <div
        class="bento-tile col-span-2 row-span-1 intro-tile"
        transition:name="bento-werk"
      >
        <div class="content-wrapper">
          <a href="/" class="back-link">&larr; Terug naar Home</a>
          <h1>Mijn Werk</h1>
          <p>Een overzicht van alle projecten gebouwd tijdens deze minor.</p>
        </div>
      </div>

      {
        projecten.map((project, index) => (
          <a
            href={`/werk/${project.id}`}
            class={`bento-tile project-tile ${getBentoClass(index)}`}
            transition:name={`card-${project.id}`}
          >
            {project.data.cover && (
              <Image
                src={project.data.cover}
                alt={project.data.alt_tekst || project.data.title}
                class="project-bg"
                transition:name={`cover-${project.id}`}
              />
            )}
            <div class="overlay" />
            <div class="content">
              <h2 transition:name={`title-${project.id}`}>
                {project.data.title}
              </h2>
              <p class="omschrijving">{project.data.omschrijving}</p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</MainLayout>

<style>
  /* =========================================================================
     DE SCROLL-FIX WRAPPER (Zelfde als Homepage)
     ========================================================================= */
  .home-wrapper {
    height: 100dvh;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 1.5rem;
  }

  .werk-grid {
    width: 100%;
    max-width: 1200px;
    height: 100%;
    max-height: 85vh;
    /* DENSE zorgt ervoor dat lege gaten in het grid automatisch worden opgevuld! */
    grid-auto-flow: dense;
    grid-template-rows: repeat(3, 1fr);
    grid-auto-rows: unset;
  }

  /* Zorgt dat tiles inkrimpen op kleinere schermen */
  .werk-grid .bento-tile {
    min-height: 0;
  }

  /* =========================================================================
     1. UITLEG TEGEL (Uniek voor Werk)
     ========================================================================= */
  .intro-tile {
    justify-content: center;
    padding: 1.5rem 2rem;
  }
  .intro-tile h1 {
    font-size: clamp(2rem, 3vw, 2.5rem);
  }

  /* =========================================================================
     2. PROJECT TEGELS
     ========================================================================= */
  .project-tile {
    justify-content: flex-end;
    padding: 1.5rem;
    border: none;
  }

  .project-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    transition: transform 0.5s ease;
  }

  .project-tile:hover .project-bg {
    transform: scale(1.05);
  }

  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to top,
      rgba(15, 23, 42, 0.95) 0%,
      rgba(15, 23, 42, 0.2) 100%
    );
    z-index: 2;
    transition: background 0.3s ease;
  }

  .project-tile:hover .overlay {
    background: linear-gradient(
      to top,
      rgba(15, 23, 42, 0.9) 0%,
      rgba(15, 23, 42, 0.4) 100%
    );
  }

  .content {
    position: relative;
    z-index: 3;
  }
  .content h2 {
    margin: 0 0 0.25rem 0;
    color: #ffffff;
    font-size: 1.4rem;
    line-height: 1.2;
    transition: color 0.3s ease;
  }
  .project-tile:hover .content h2 {
    color: var(--primary-color);
  }

  .content .omschrijving {
    margin: 0;
    color: #cbd5e1;
    font-size: 0.95rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
